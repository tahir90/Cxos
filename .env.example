# ── Required for production ──────────────────────────────────────
# Set CXO_ENV=production to enforce strict config validation
# CXO_ENV=development

# JWT secret — MUST be set in production (e.g. openssl rand -hex 32)
CXO_JWT_SECRET=change-me-in-production

# Admin user created on first run — MUST change password in production
CXO_ADMIN_EMAIL=admin@cxo.ai
CXO_ADMIN_PASSWORD=change-me-in-production

# Credential encryption — set for encrypted connector credentials
# CXO_ENCRYPTION_KEY=your-32-byte-key-base64

# ── LLM (required for AI features) ────────────────────────────────
# PREFERRED: Anthropic Claude — api.anthropic.com is reachable in this deployment.
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251022   # default; use claude-haiku-4-5-20251001 for speed

# FALLBACK: OpenAI — NOTE: api.openai.com is NOT accessible in this deployment environment.
# Only useful if OPENAI_BASE_URL points to a reachable proxy/endpoint.
OPENAI_API_KEY=sk-your-key-here

# Optional: override OpenAI base URL (e.g. local LLM, Azure OpenAI, LiteLLM proxy)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Database ─────────────────────────────────────────────────────
# SQLite by default; use Postgres URL for production
# DATABASE_URL=sqlite:///.cxo_data/cxo.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/cxo

# ── Deployment ────────────────────────────────────────────────────
# Railway/Fly.io use these for OAuth callbacks
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
