# Required for LLM-powered enrichment, summarization, and agent reasoning.
# Without this, the system falls back to rule-based/extractive mode.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the OpenAI-compatible base URL (e.g. for local LLMs)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Admin password for initial account setup
CXO_ADMIN_PASSWORD=your-password-here

# JWT secret for token signing (change in production!)
# CXO_JWT_SECRET=your-random-secret-here

# Optional: database URL (defaults to SQLite at .cxo_data/cxo.db)
# DATABASE_URL=postgresql://user:pass@host/db
